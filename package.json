{
  "name": "@giantcontext/sdk-typescript",
  "version": "1.68.0",
  "type": "module",
  "description": "GiantContext TypeScript SDK",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "format": "prettier --write --cache src/",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dogfood:check": "tsx dogfood-check.ts"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "vitest": "^3.2.1",
    "dotenv": "^17.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2"
  }
}
